{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "src/generated/daml.js/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:netlify": "node scripts/gen-redirects.js && tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "generate:api": "openapi-typescript http://localhost:7575/docs/openapi -o src/generated/ledger-api.d.ts"
  },
  "dependencies": {
    "@daml/types": "3.5.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
